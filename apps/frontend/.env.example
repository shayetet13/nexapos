# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_ANON_KEY

# ── API Routing ────────────────────────────────────────────────────────────────
# Production:  Cloudflare Worker URL  (ใช้สำหรับ REST API ผ่าน edge)
# Development: http://localhost:4000
NEXT_PUBLIC_API_URL=https://pos-cloud-worker.YOUR_SUBDOMAIN.workers.dev

# Dev บนเครื่อง: ถ้า NEXT_PUBLIC_API_URL ยังชี้ production แต่รัน Fastify ที่ localhost
# ให้ตั้งบรรทัดนี้เป็น http://localhost:4000 เพื่อให้ทั้งแอดมินและล็อกอินพนักงานใช้ DB เดียวกัน
# (ไม่ตั้งใน production)
# NEXT_PUBLIC_LOCAL_API_URL=http://localhost:4000

# Direct Fastify backend URL — ใช้สำหรับ:
#   • WebSocket connection (CF Worker ไม่ proxy WS upgrades)
#   • Customer display broadcast (POST /api/v1/shops/:id/display)
# Production:  https://pos-backend.up.railway.app
# Development: http://localhost:4000
NEXT_PUBLIC_API_URL_DIRECT=https://pos-backend.up.railway.app

# Server-side only — URL ที่ Next.js API routes ใช้เรียก Fastify โดยตรง (ไม่ผ่าน Worker)
# สำคัญ: ต้องตั้งค่าใน production environment ไม่เช่นนั้น register/OTP/auth จะ 503
# Production:  https://pos-backend.up.railway.app  (หรือ internal hostname ถ้า same cluster)
# Development: http://localhost:4000
BACKEND_URL=https://pos-backend.up.railway.app

# Server-side only — ต้องตรงกับ Fastify `INTERNAL_TOKEN` และ Cloudflare Worker (ถ้าใช้)
# ถ้า backend เปิด internal-token guard แต่ค่านี้ว่าง → `/api/staff-login` และ proxy อื่นจะได้ 401
INTERNAL_TOKEN=

# ── WebSocket ─────────────────────────────────────────────────────────────────
# ต้องชี้ตรงไป Fastify backend (ไม่ผ่าน Worker)
# Production:  wss://pos-backend.up.railway.app
# Development: ws://localhost:4000
NEXT_PUBLIC_WS_URL=wss://pos-backend.up.railway.app

# ── Stripe Payment Links ───────────────────────────────────────────────────────
# สร้างใน Stripe Dashboard → Payment Links
NEXT_PUBLIC_STRIPE_LINK_MONTHLY=https://buy.stripe.com/REPLACE_MONTHLY
NEXT_PUBLIC_STRIPE_LINK_YEARLY=https://buy.stripe.com/REPLACE_YEARLY

# ── Dev Access (ใส่ว่างใน production) ────────────────────────────────────────
NEXT_PUBLIC_DEV_ADMIN_EMAILS=
